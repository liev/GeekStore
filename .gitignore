# ==========================================
# GeekStore — .gitignore
# ==========================================

# ── .NET / Backend ──────────────────────────
bin/
obj/
*.db
*.db-shm
*.db-wal
*.user
*.suo
*.cache
*.log
.vs/
appsettings.Development.json
appsettings.Production.json

# ── Node / Frontend ─────────────────────────
node_modules/
dist/
.env
.env.*
!.env.example

# ── IDE ─────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS ──────────────────────────────────────
Thumbs.db
.DS_Store

# ── Misc / Temp ─────────────────────────────
diff.txt
*.tmp
eslint_report.json
eslint_compact.txt
lint_output.json
lint_output_utf8.json

# ── Build artifacts / CI logs ────────────────
build_errors*.txt
build_output*.txt
build_args.txt
clean_errors.txt
